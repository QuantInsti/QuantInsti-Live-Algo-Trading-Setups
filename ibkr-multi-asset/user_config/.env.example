# Multi-Asset Setup: Environment Variables
# Copy this file to .env and fill in your real values.
# .env is kept out of version control (in .gitignore).
#
# cp .env.example .env

# IBKR Account (paper or live)
IBKR_ACCOUNT=DU1234567

# Gmail SMTP (use an App Password, not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your_email@gmail.com
TO_EMAIL=your_email@gmail.com
SMTP_APP_PASSWORD="your_16_char_app_password"
